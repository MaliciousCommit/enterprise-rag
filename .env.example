# .env.example
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# This .env.example IS committed — it documents required variables
# without exposing actual values.

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...your-key-here...

# ── Qdrant ───────────────────────────────────────────────────────────────────
# Local Docker (default for development):
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=                    # leave empty for local, set for Qdrant Cloud

# For Qdrant Cloud (production):
# QDRANT_HOST=your-cluster.qdrant.io
# QDRANT_PORT=6333
# QDRANT_API_KEY=your-cloud-api-key

# ── Collection ───────────────────────────────────────────────────────────────
COLLECTION_NAME=k8s_docs_m1        # Suffix with _m1 so we can tell which phase built it

# ── LLM Settings ─────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1

# ── Embedding Settings ────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=400                     # tokens per chunk (400-600 is typical)
CHUNK_OVERLAP=80                   # overlap tokens between adjacent chunks

# ── Retrieval ────────────────────────────────────────────────────────────────
RETRIEVAL_K=5                      # how many chunks to retrieve per query

# ── Future phases (add these variables when we reach each phase) ─────────────

# Phase 4 (PostgreSQL):
# POSTGRES_URL=postgresql://raguser:ragpass@localhost:5432/enterprise_rag

# Phase 6 (Redis):
# REDIS_URL=redis://localhost:6379

# Phase 8 (Guardrails):
# LLMGUARD_ENABLED=true

# Phase 9 (Observability):
# LANGSMITH_API_KEY=ls__...
# LANGSMITH_PROJECT=enterprise-rag-dev
